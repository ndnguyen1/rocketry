  RTWGenerateCodeOnly	  off
  RTWRetainRTWFile	  off
  TLCProfiler		  off
  TLCDebug		  off
  TLCCoverage		  off
  TLCAssertion		  off
  BlockDefaults {
    Orientation		    "right"
    ForegroundColor	    "black"
    BackgroundColor	    "white"
    DropShadow		    off
    NamePlacement	    "normal"
    FontName		    "Helvetica"
    FontSize		    10
    FontWeight		    "normal"
    FontAngle		    "normal"
    ShowName		    on
  }
  BlockParameterDefaults {
    Block {
      BlockType		      Inport
      Port		      "1"
      PortDimensions	      "-1"
      ShowAdditionalParam     off
      LatchInput	      off
      DataType		      "auto"
      OutDataType	      "sfix(16)"
      OutScaling	      "2^0"
      SignalType	      "auto"
      SamplingMode	      "auto"
      Interpolate	      on
    }
    Block {
      BlockType		      Outport
      Port		      "1"
      OutputWhenDisabled      "held"
      InitialOutput	      "[]"
    }
  }
  AnnotationDefaults {
    HorizontalAlignment	    "center"
    VerticalAlignment	    "middle"
    ForegroundColor	    "black"
    BackgroundColor	    "white"
    DropShadow		    off
    FontName		    "Helvetica"
    FontSize		    10
    FontWeight		    "normal"
    FontAngle		    "normal"
  }
  LineDefaults {
    FontName		    "Helvetica"
    FontSize		    9
    FontWeight		    "normal"
    FontAngle		    "normal"
  }
  System {
    Name		    "Template"
    Location		    [190, 106, 919, 606]
    Open		    on
    ModelBrowserVisibility  off
    ModelBrowserWidth	    200
    ScreenColor		    "white"
    PaperOrientation	    "landscape"
    PaperPositionMode	    "auto"
    PaperType		    "A4"
    PaperUnits		    "centimeters"
    ZoomFactor		    "100"
    ReportName		    "simulink-default.rpt"
    Block {
      BlockType		      Inport
      Name		      "In1"
      Tag		      "REF1"
      Description	      "VREF or VAR(STRTIN(3,SLOT) depending on whether"
" an AVR or GOV."
      Position		      [70, 58, 100, 72]
      AttributesFormatString  "REF"
    }
    Block {
      BlockType		      Inport
      Name		      "In2"
      Tag		      "EC"
      Description	      "ECOMP is the voltage regulator compensated volt"
"age for AVR in p.u.\nor SPEED is speed deviation from nominal for GOV in p.u."
"          "
      Position		      [70, 128, 100, 142]
      AttributesFormatString  "ECOMP/SPEED"
      Port		      "2"
    }
    Block {
      BlockType		      Inport
      Name		      "In3"
      Tag		      "IT"
      Description	      "TERMCURR is the magnitude of terminal current i"
"n p.u."
      Position		      [70, 188, 100, 202]
      AttributesFormatString  "TERMCURR"
      Port		      "3"
    }
    Block {
      BlockType		      Inport
      Name		      "In4"
      Tag		      "IR"
      Description	      "REALCURR is the magnitude of real current compo"
"nent in p.u."
      Position		      [70, 253, 100, 267]
      AttributesFormatString  "REALCURR"
      Port		      "4"
    }
    Block {
      BlockType		      Inport
      Name		      "In5"
      Tag		      "IM"
      Description	      "IMAGCURR is the magnitude of imaginary current "
"component in p.u."
      Position		      [70, 313, 100, 327]
      AttributesFormatString  "IMAGCURR"
      Port		      "5"
    }
    Block {
      BlockType		      Inport
      Name		      "In6"
      Tag		      "XADIFD"
      Description	      "XADIFD is the field current of machine in p.u."
      Position		      [70, 378, 100, 392]
      AttributesFormatString  "XADIFD"
      Port		      "6"
    }
    Block {
      BlockType		      Inport
      Name		      "In7"
      Tag		      "PELEC"
      Description	      "PELEC is real electrical power of machine in p."
"u."
      Position		      [70, 438, 100, 452]
      AttributesFormatString  "PELEC"
      Port		      "7"
    }
    Block {
      BlockType		      Inport
      Name		      "In8"
      Tag		      "QELEC"
      Description	      "QELEC is reactive electrical power of machine i"
"n p.u."
      Position		      [210, 58, 240, 72]
      AttributesFormatString  "QELEC"
      Port		      "8"
    }
    Block {
      BlockType		      Inport
      Name		      "In9"
      Tag		      "ANGLE"
      Description	      "ANGLE is rotor angle of machine in degrees."
      Position		      [210, 123, 240, 137]
      AttributesFormatString  "ANGLE"
      Port		      "9"
    }
    Block {
      BlockType		      Inport
      Name		      "In10"
      Tag		      "BSF"
      Description	      "BSFREQ is bus frequency deviation in p.u."
      Position		      [210, 188, 240, 202]
      AttributesFormatString  "BSFREQ"
      Port		      "10"
    }
    Block {
      BlockType		      Inport
      Name		      "In11"
      Tag		      "VUEL"
      Description	      "VUEL is output from minimum excitation limiter "
"in p.u."
      Position		      [210, 253, 240, 267]
      AttributesFormatString  "VUEL"
      Port		      "11"
    }
    Block {
      BlockType		      Inport
      Name		      "In12"
      Tag		      "VOEL"
      Description	      "VOEL  is output from maximum excitation limiter"
" in p.u."
      Position		      [205, 318, 235, 332]
      AttributesFormatString  "VOEL"
      Port		      "12"
    }
    Block {
      BlockType		      Inport
      Name		      "In13"
      Tag		      "VOTHSG"
      Description	      "VOTHSG is auxiliary signal from stabiliser or c"
"ompensator in p.u."
      Position		      [205, 378, 235, 392]
      AttributesFormatString  "VOTHSG"
      Port		      "13"
    }
    Block {
      BlockType		      Inport
      Name		      "In14"
      Tag		      "ETERM"
      Description	      "ETERM  is the terminal voltage in p.u."
      Position		      [205, 438, 235, 452]
      AttributesFormatString  "ETERM"
      Port		      "14"
    }
    Block {
      BlockType		      Inport
      Name		      "In15"
      Tag		      "PMAX"
      Description	      "Not used at present"
      Position		      [320, 58, 350, 72]
      AttributesFormatString  "NOT USED"
      Port		      "15"
    }
    Block {
      BlockType		      Inport
      Name		      "In16"
      Tag		      "REF2"
      Description	      "Not used at present"
      Position		      [320, 123, 350, 137]
      AttributesFormatString  "NOT USED"
      Port		      "16"
    }
    Block {
      BlockType		      Inport
      Name		      "In17"
      Tag		      "PORDINIT"
      Description	      "Not used at present"
      Position		      [320, 183, 350, 197]
      AttributesFormatString  "NOT USED"
      Port		      "17"
    }
    Block {
      BlockType		      Outport
      Name		      "Out1"
      Tag		      "EFPM"
      Description	      "PMECH or EFD in p.u. for GOV or AVR."
      Position		      [530, 63, 560, 77]
      AttributesFormatString  "EFD/PMECH"
    }
    Block {
      BlockType		      Outport
      Name		      "Out2"
      Tag		      "QORD"
      Description	      "Not used at present"
      Position		      [530, 128, 560, 142]
      AttributesFormatString  "NOT USED"
      Port		      "2"
    }
  }
}
